<!-- ═══════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════ -->
<script>
  // ── Sample prompts for carousel ──
  const PROMPTS = [
    "What is Adaptive Adoption and how does it differ from Kotter?",
    "Does Paul have evidence for his claims about culture change?",
    "What is the Intention-Action Gap and why does it matter for AI?",
    "What does the Corpus say about trust as infrastructure?",
    "How does behavioral governance differ from traditional compliance?",
    "What is Oracle Science and why does it matter for the future of research?",
    "Where does Paul disagree with mainstream change management?",
    "What connects epistemic strength and organizational learning?",
  ];

  // ── Carousel ──
  (function() {
    const track = document.getElementById('carousel-track');
    if (!track) return;
    const VISIBLE = window.innerWidth > 700 ? 3 : 1;
    let offset = 0;
    let autoTimer;

    function render() {
      track.innerHTML = '';
      for (let i = 0; i < VISIBLE; i++) {
        const idx = (offset + i) % PROMPTS.length;
        const el = document.createElement('div');
        el.className = 'chat-carousel-prompt';
        el.textContent = PROMPTS[idx];
        el.addEventListener('click', function() {
          const input = document.getElementById('chatbox-input');
          if (input) {
            input.value = PROMPTS[idx];
            input.focus();
          }
        });
        track.appendChild(el);
      }
    }

    function advance(dir) {
      offset = (offset + dir + PROMPTS.length) % PROMPTS.length;
      render();
      resetAuto();
    }

    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(function() { advance(1); }, 5000);
    }

    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');
    if (prevBtn) prevBtn.addEventListener('click', function() { advance(-1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { advance(1); });

    render();
    resetAuto();
  })();


  // ── Chatbox: send ──
  (function() {
    const input = document.getElementById('chatbox-input');
    const sendBtn = document.getElementById('chatbox-send');
    const messages = document.getElementById('chatbox-messages');
    let emptyEl = document.getElementById('chatbox-empty');

    if (!input || !sendBtn || !messages) return;

    function send() {
      const q = input.value.trim();
      if (!q) return;

      if (emptyEl && emptyEl.parentNode) {
        emptyEl.parentNode.removeChild(emptyEl);
        emptyEl = null;
      }

      // User message
      const userMsg = document.createElement('div');
      userMsg.className = 'msg msg-user';
      userMsg.textContent = q;
      messages.appendChild(userMsg);

      input.value = '';

      // Typing indicator
      const typing = document.createElement('div');
      typing.className = 'msg msg-typing';
      typing.textContent = 'Searching 1,010 passages...';
      messages.appendChild(typing);
      messages.scrollTop = messages.scrollHeight;

      // API call
      fetch('/api/query', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: q })
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        typing.remove();
        const botMsg = document.createElement('div');
        botMsg.className = 'msg msg-bot';
        if (data.error) {
          botMsg.textContent = data.error;
        } else {
          const sourceLine = data.sources && data.sources.length
            ? '<div class="msg-sources">Sources: ' + data.sources.join(' \u00b7 ') + '</div>'
            : '';
          botMsg.innerHTML = data.answer.replace(/\n/g, '<br>') + sourceLine;
        }
        messages.appendChild(botMsg);
        messages.scrollTop = messages.scrollHeight;
      })
      .catch(function() {
        typing.remove();
        const errMsg = document.createElement('div');
        errMsg.className = 'msg msg-bot';
        errMsg.textContent = 'Something went wrong. Please try again.';
        messages.appendChild(errMsg);
        messages.scrollTop = messages.scrollHeight;
      });
    }

    sendBtn.addEventListener('click', send);
    input.addEventListener('keydown', function(e) { if (e.key === 'Enter') send(); });
  })();


  // ── Question chips → chatbox ──
  (function() {
    document.querySelectorAll('.question-chip').forEach(function(chip) {
      chip.addEventListener('click', function() {
        const q = chip.getAttribute('data-question');
        const input = document.getElementById('chatbox-input');
        const chatbox = document.getElementById('chatbox');
        if (input && q) {
          input.value = q;
          if (chatbox) chatbox.scrollIntoView({ behavior: 'smooth' });
          setTimeout(function() { input.focus(); }, 600);
        }
      });
    });
  })();


  // ── Floating CTA ──
  (function() {
    const cta = document.getElementById('float-cta');
    const ctaBtn = document.getElementById('float-cta-btn');
    const chatbox = document.getElementById('chatbox');

    if (!cta || !ctaBtn || !chatbox) return;

    ctaBtn.addEventListener('click', function(e) {
      e.preventDefault();
      chatbox.scrollIntoView({ behavior: 'smooth' });
      setTimeout(function() {
        const input = document.getElementById('chatbox-input');
        if (input) input.focus();
      }, 600);
    });

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          cta.classList.remove('visible');
        } else {
          cta.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    observer.observe(chatbox);
  })();
</script>
