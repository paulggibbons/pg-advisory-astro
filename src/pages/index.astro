---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import BureauStrip from '../components/BureauStrip.astro';
import Services from '../components/Services.astro';
import Credentials from '../components/Credentials.astro';
import Positioning from '../components/Positioning.astro';
import OpenFramework from '../components/OpenFramework.astro';
import Corpus from '../components/Corpus.astro';
import Testimonials from '../components/Testimonials.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
---

<Base>
  <Fragment slot="head">
    <SEO
      title="Paul Gibbons Advisory — AI Strategy. Human Change."
      description="Paul Gibbons is an AI adoption strategist, keynote speaker, and author of 8 books. Creator of the Adaptive Adoption framework — leadership, governance, and behavioral science for enterprise AI."
      canonicalUrl="/"
    />
  </Fragment>

  <!-- Splash overlay — shows once per session -->
  <div class="splash-overlay" id="splash-overlay">
    <p class="splash-text">AI has moved the goalposts for leading change.</p>
  </div>

  <style>
    .splash-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(170deg, var(--espresso) 0%, var(--chocolate) 40%, var(--chocolate-mid) 100%);
      opacity: 1;
      transition: opacity 0.6s ease;
      pointer-events: all;
    }

    .splash-overlay.fade-out {
      opacity: 0;
      pointer-events: none;
    }

    .splash-text {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(28px, 4vw, 52px);
      color: var(--cream);
      text-align: center;
      max-width: 700px;
      padding: 0 32px;
      line-height: 1.3;
    }
  </style>

  <script>
    (function() {
      const overlay = document.getElementById('splash-overlay');
      if (!overlay) return;
      if (sessionStorage.getItem('splash-shown')) {
        overlay.remove();
        return;
      }
      sessionStorage.setItem('splash-shown', '1');
      setTimeout(function() {
        overlay.classList.add('fade-out');
        setTimeout(function() { overlay.remove(); }, 600);
      }, 1500);
    })();
  </script>

  <Nav />
  <Hero />
  <BureauStrip />
  <Services />
  <Credentials />
  <Positioning />
  <OpenFramework />
  <Corpus />
  <Testimonials />
  <CtaSection />
  <Footer />
</Base>
