---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import BureauStrip from '../components/BureauStrip.astro';
import Services from '../components/Services.astro';
import Credentials from '../components/Credentials.astro';
import Positioning from '../components/Positioning.astro';
import OpenFramework from '../components/OpenFramework.astro';
import Corpus from '../components/Corpus.astro';
import Testimonials from '../components/Testimonials.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
---

<Base>
  <Fragment slot="head">
    <SEO
      title="Paul Gibbons Advisory — People-First AI Adoption"
      description="Paul Gibbons is an AI adoption strategist, keynote speaker, and author of 8 books. Creator of the Adaptive Adoption framework — leadership, governance, and behavioral science for enterprise AI."
      canonicalUrl="/"
    />
  </Fragment>
  <Nav />
  <Hero />
  <BureauStrip />
  <Services />
  <Credentials />
  <Positioning />
  <OpenFramework />
  <Corpus />
  <Testimonials />
  <CtaSection />
  <Footer />
</Base>
