---
---

<section class="open-framework" id="open-framework">
  <div class="of-inner">
    <div class="of-label">Open Framework</div>
    <h2 class="of-headline"><span style="color:#3DCC80;">Use It.</span> <span style="color:#5BA3D9;">Study It.</span> <span style="color:#E8944A;">Challenge It.</span> <span style="color:#B07DD6;">Improve It.</span></h2>
    <p class="of-subhead"><strong style="color:var(--cream);font-weight:400;font-style:italic;">When management ideas live in PDFs, they become rigid. It is not just organizations that need to be adaptable — so do our methods of changing them.</strong></p>
    <p class="of-subhead" style="margin-top:-32px;">The tools, diagnostics, whitepapers, and methods are open, inspectable, and designed to improve in the open.</p>

    <div class="of-grid">

      <!-- Left column: four verbs + audience -->
      <div>
        <div class="of-verbs">
          <div class="of-verb">
            <div class="of-verb-icon" style="color:#3DCC80;">&rarr;</div>
            <div class="of-verb-content">
              <div class="of-verb-title" style="color:#3DCC80;">Use It</div>
              <div class="of-verb-desc">Download templates, diagnostics, scoresheets, and skills. Run them with your teams tomorrow.</div>
            </div>
          </div>
          <div class="of-verb">
            <div class="of-verb-icon" style="color:#5BA3D9;">&rarr;</div>
            <div class="of-verb-content">
              <div class="of-verb-title" style="color:#5BA3D9;">Study It</div>
              <div class="of-verb-desc">Read the theory whitepapers, logic traces, and intellectual provenance behind every dimension.</div>
            </div>
          </div>
          <div class="of-verb">
            <div class="of-verb-icon" style="color:#E8944A;">&rarr;</div>
            <div class="of-verb-content">
              <div class="of-verb-title" style="color:#E8944A;">Challenge It</div>
              <div class="of-verb-desc">Comment on the framework. Flag what's wrong. Argue for what's missing. The framework gets better when it's contested.</div>
            </div>
          </div>
          <div class="of-verb">
            <div class="of-verb-icon" style="color:#B07DD6;">&rarr;</div>
            <div class="of-verb-content">
              <div class="of-verb-title" style="color:#B07DD6;">Improve It</div>
              <div class="of-verb-desc">Propose new tools, submit behavioral templates, suggest upgrades to the repo.</div>
            </div>
          </div>
        </div>

        <div class="of-audience">
          <div class="of-audience-label">BUILT FOR</div>
          <div class="of-audience-tags">
            <span class="of-tag">Change Leaders</span>
            <span class="of-tag">Frontline Digital Enablers</span>
            <span class="of-tag">Developers</span>
            <span class="of-tag">HR &amp; L&amp;D Specialists</span>
            <span class="of-tag">COOs &amp; CAIOs</span>
          </div>
        </div>
      </div>

      <!-- Right column: Do This First -->
      <div class="of-start">
        <div class="of-start-label">DO THIS FIRST</div>
        <div class="of-steps">
          <div class="of-step">
            <div class="of-step-num">1</div>
            <div class="of-step-text"><strong>Click the link below.</strong> It opens the Adaptive Adoption repository.</div>
          </div>
          <div class="of-step">
            <div class="of-step-num">2</div>
            <div class="of-step-text"><strong>Browse the folders.</strong> Each one is a layer of the framework — Leadership Delta, Change Agility, Behavioral Governance.</div>
          </div>
          <div class="of-step">
            <div class="of-step-num">3</div>
            <div class="of-step-text"><strong>Download what you need.</strong> No account required. No gates. No fees.</div>
          </div>
        </div>

        <a href="https://github.com/paulggibbons/adaptive_adoption" target="_blank" rel="noopener" class="of-cta">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          OPEN THE REPOSITORY
        </a>
        <div class="of-note">No GitHub account needed to browse or download.</div>
      </div>

    </div>
  </div>
</section>

<style>
  .open-framework {
    --chocolate: #2c1e14;
    --chocolate-mid: #3d2b1e;
    --espresso: #1a120b;
    --cream: #f5f0e8;
    --cream-soft: #ede7dc;
    --gold: #b8922a;
    --gold-glow: rgba(184, 146, 42, 0.3);
    --mid: #6b6560;

    background: linear-gradient(170deg, #1a120b 0%, #2c1e14 50%, #1a120b 100%);
    padding: 80px 48px;
    position: relative;
    overflow: hidden;
  }

  .open-framework::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
  }

  .open-framework::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
  }

  .of-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .of-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12px;
    letter-spacing: 6px;
    color: var(--gold);
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .of-headline {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(32px, 4vw, 48px);
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 12px;
  }

  .of-subhead {
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    color: rgba(245, 240, 232, 0.6);
    line-height: 1.6;
    max-width: 700px;
    margin-bottom: 48px;
  }

  .of-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .of-verbs {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .of-verb {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .of-verb-icon {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--gold);
    line-height: 1;
    min-width: 40px;
    padding-top: 2px;
  }

  .of-verb-title {
    font-family: 'DM Serif Display', serif;
    font-size: 20px;
    color: var(--cream);
    margin-bottom: 4px;
  }

  .of-verb-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: rgba(245, 240, 232, 0.55);
    line-height: 1.5;
  }

  .of-audience {
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid rgba(184, 146, 42, 0.15);
  }

  .of-audience-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--gold);
    margin-bottom: 14px;
  }

  .of-audience-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .of-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--cream-soft);
    padding: 6px 16px;
    border: 1px solid rgba(184, 146, 42, 0.25);
    border-radius: 2px;
    background: rgba(184, 146, 42, 0.06);
  }

  .of-start {
    background: rgba(245, 240, 232, 0.03);
    border: 1px solid rgba(184, 146, 42, 0.12);
    padding: 36px 32px;
  }

  .of-start-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 3px;
    color: var(--gold);
    margin-bottom: 28px;
  }

  .of-steps {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 36px;
  }

  .of-step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .of-step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    color: var(--gold);
    line-height: 1;
    min-width: 28px;
    opacity: 0.6;
  }

  .of-step-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: var(--cream-soft);
    line-height: 1.5;
    padding-top: 4px;
  }

  .of-step-text strong {
    color: var(--cream);
    font-weight: 500;
  }

  .of-cta {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 28px;
    background: var(--gold);
    color: var(--espresso);
    text-decoration: none;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    letter-spacing: 3px;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
  }

  .of-cta:hover {
    background: var(--cream);
    box-shadow: 0 0 40px var(--gold-glow);
  }

  .of-cta svg {
    width: 28px;
    height: 28px;
    fill: currentColor;
  }

  .of-note {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: rgba(245, 240, 232, 0.35);
    margin-top: 12px;
  }

  @media (max-width: 768px) {
    .open-framework { padding: 60px 24px; }
    .of-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
