<section class="cta-section" id="engage">
  <div class="section-inner">
    <h2 class="cta-headline reveal">Ready to make AI adoption <em>work</em>?</h2>
    <p class="cta-sub reveal">Speaking engagements, advisory, or fractional CAIO — let's find the right fit.</p>
    <div class="cta-buttons reveal">
      <a href="mailto:paul@paulgibbonsadvisory.com" class="btn-primary">Engage</a>
      <a href="#about" class="btn-outline">Explore the Framework</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 120px 48px;
    background: var(--espresso);
    text-align: center;
    position: relative;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184, 146, 42, 0.1), transparent 70%);
    filter: blur(60px);
  }

  .cta-headline {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(32px, 4vw, 56px);
    color: var(--cream);
    max-width: 600px;
    margin: 0 auto 20px;
    line-height: 1.1;
    position: relative;
  }

  .cta-headline em {
    font-style: italic;
    color: var(--gold);
  }

  .cta-sub {
    font-size: 17px;
    color: rgba(245, 240, 232, 0.8);
    max-width: 500px;
    margin: 0 auto 40px;
    font-weight: 300;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .cta-section { padding: 120px 24px; }
  }
</style>
