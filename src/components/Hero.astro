<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-glow"></div>

  <div class="hero-content">
    <div class="hero-text">
      <div class="hero-label">Change Leadership for the AI Era</div>
      <h1 class="hero-headline">
        AI Strategy. Human Change.
      </h1>
      <p class="hero-sub">
        Spending more on technology isn't the answer. Leadership, governance, and change capability are the human infrastructure that determines whether AI investments create value or drain it.
      </p>
      <div class="hero-ctas">
        <a href="mailto:paul@paulgibbonsadvisory.com" class="btn-primary">Engage</a>
        <a href="#about" class="btn-ghost">Discover Adaptive Adoption &rarr;</a>
      </div>
    </div>

    <div class="hero-image">
      <img
        src="/images/paul-speaking.jpg"
        alt="Paul Gibbons speaking on stage"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: auto;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 120px 48px 0;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 70% 40%, rgba(60, 40, 20, 0.7), transparent),
      radial-gradient(ellipse 50% 50% at 20% 80%, rgba(184, 146, 42, 0.05), transparent),
      linear-gradient(170deg, var(--espresso) 0%, var(--chocolate) 40%, var(--chocolate-mid) 100%);
    z-index: 0;
  }

  .hero-glow {
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184, 146, 42, 0.08), transparent 70%);
    top: 10%; right: -5%;
    z-index: 1;
    animation: glowPulse 8s ease-in-out infinite alternate;
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .hero-text { max-width: 600px; }

  .hero-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 12px;
    letter-spacing: 6px;
    color: #c8a84e;
    margin-bottom: 24px;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease forwards 0.3s;
  }

  .hero-headline {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(40px, 5vw, 68px);
    line-height: 1.05;
    color: var(--cream);
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.8s ease forwards 0.5s;
  }

  .hero-sub {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(245, 240, 232, 0.7);
    font-weight: 300;
    max-width: 500px;
    margin-bottom: 40px;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.8s ease forwards 0.7s;
  }

  .hero-ctas {
    display: flex;
    gap: 20px;
    align-items: center;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s ease forwards 0.9s;
  }

  .hero-image {
    position: relative;
    opacity: 0;
    transform: translateX(40px);
    animation: fadeInRight 1s ease forwards 0.6s;
    align-self: stretch;
    min-height: 500px;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
    filter: brightness(0.9) contrast(1.05);
  }

  .hero-image::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(transparent, var(--espresso));
    pointer-events: none;
  }

  .hero-image::before {
    content: '';
    position: absolute;
    inset: -20px;
    border: 1px solid rgba(184, 146, 42, 0.15);
    z-index: -1;
  }

  @media (max-width: 900px) {
    .hero { padding: 120px 24px 0; }
    .hero-content { grid-template-columns: 1fr; gap: 40px; }
    .hero-image { max-width: 500px; }
  }

  @media (max-width: 640px) {
    .hero-headline { font-size: 36px; }
  }
</style>
