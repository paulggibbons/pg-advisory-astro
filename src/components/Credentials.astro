---
const logos = ['Shell', 'Barclays', 'Microsoft', 'Unilever', 'HSBC', 'Bayer', 'Philips', 'Deloitte', 'IBM', 'Comcast', 'KPMG', 'BP'];
---

<section class="credentials">
  <div class="section-inner">
    <p class="cred-quote reveal">
      &ldquo;The human-capital strategist for the <span>AI era</span>&rdquo;
    </p>

    <div class="logo-strip-wrapper">
      <div class="logo-strip">
        {logos.map(name => <span class="logo-item">{name}</span>)}
        {logos.map(name => <span class="logo-item">{name}</span>)}
      </div>
    </div>

    <div class="cred-stats reveal">
      <div class="cred-stat">
        <div class="cred-stat-num" style="color:#5BA3D9;">8</div>
        <div class="cred-stat-label">Books, One Bestseller</div>
      </div>
      <div class="cred-stat">
        <div class="cred-stat-num" style="color:#E8944A;">30+</div>
        <div class="cred-stat-label">Years in Strategy, Change &amp; Leadership</div>
      </div>
      <div class="cred-stat">
        <div class="cred-stat-num" style="color:#3DCC80;">100+</div>
        <div class="cred-stat-label">Keynotes Delivered</div>
      </div>
      <div class="cred-stat">
        <div class="cred-stat-num" style="color:#B07DD6;">Top-52</div>
        <div class="cred-stat-label">To Follow in AI — Fortune 100 AI Leader</div>
      </div>
    </div>

    <div class="cred-stats cred-stats-institutional reveal">
      <div class="cred-stat">
        <div class="cred-stat-num institutional" style="color:#5BA3D9;">IBM</div>
        <div class="cred-stat-label">Partner &amp; Thought Leader</div>
      </div>
      <div class="cred-stat">
        <div class="cred-stat-num institutional" style="color:#3DCC80;">U. of Denver</div>
        <div class="cred-stat-label">Adjunct Professor</div>
      </div>
      <div class="cred-stat">
        <div class="cred-stat-num institutional" style="color:#B07DD6;">Deloitte</div>
        <div class="cred-stat-label">Senior Academic Adviser</div>
      </div>
    </div>
  </div>
</section>

<style>
  .credentials {
    padding: 100px 48px;
    background: var(--espresso);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .credentials::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 40% at 50% 50%, rgba(184, 146, 42, 0.04), transparent);
  }

  .credentials .section-inner { position: relative; z-index: 2; }

  .cred-quote {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(24px, 3vw, 38px);
    font-style: italic;
    color: var(--cream);
    max-width: 800px;
    margin: 0 auto 48px;
    line-height: 1.4;
  }

  .cred-quote span { color: var(--gold); }

  .logo-strip-wrapper {
    overflow: hidden;
    margin-bottom: 56px;
    position: relative;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .logo-strip {
    display: flex;
    align-items: center;
    gap: 64px;
    animation: scrollLogos 25s linear infinite;
    width: max-content;
  }

  .logo-item {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    letter-spacing: 4px;
    color: rgba(245, 240, 232, 0.35);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cred-stats {
    display: flex;
    justify-content: center;
    gap: 64px;
    flex-wrap: wrap;
  }

  .cred-stats-institutional {
    margin-top: 40px;
    padding-top: 40px;
    border-top: 1px solid rgba(184, 146, 42, 0.1);
  }

  .cred-stat { text-align: center; }

  .cred-stat-num {
    font-family: 'DM Serif Display', serif;
    font-size: 48px;
    color: var(--gold);
    line-height: 1;
  }

  .cred-stat-num.institutional {
    font-size: 32px;
  }

  .cred-stat-label {
    font-size: 13px;
    color: rgba(245, 240, 232, 0.7);
    margin-top: 8px;
    letter-spacing: 0.5px;
  }

  @media (max-width: 900px) {
    .credentials { padding: 100px 24px; }
    .cred-stats { gap: 32px; }
    .logo-strip { gap: 24px; }
  }
</style>
